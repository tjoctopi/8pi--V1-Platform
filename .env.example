# Copy to .env and fill in. Never commit .env.

# --- BYOM Model Gateway (Fireworks AI, open-source models via LiteLLM) ---
FIREWORKS_API_KEY=

# --- Engine config (all optional; sensible defaults in attack_engine.config) ---
# AE_ prefix maps to attack_engine.config.Settings fields.
AE_ENV=dev
AE_LOG_LEVEL=INFO
AE_LOG_JSON=false

# Audit log backend: "sqlite" (default) or "memory" or "postgres"
AE_AUDIT_BACKEND=sqlite
AE_AUDIT_SQLITE_PATH=./data/audit.db
# AE_AUDIT_POSTGRES_DSN=postgresql://user:pass@localhost:5432/attack_engine

# Event bus backend: "memory" (default) or "redis"
AE_EVENTBUS_BACKEND=memory
# AE_EVENTBUS_REDIS_URL=redis://localhost:6379/0

# Knowledge graph backend: "networkx" (default, in-proc) or "neo4j"
AE_GRAPH_BACKEND=networkx
# AE_NEO4J_URL=bolt://localhost:7687
# AE_NEO4J_USER=neo4j
# AE_NEO4J_PASSWORD=
# AE_NEO4J_DATABASE=default

# Tool sandbox backend: "docker" (default) or "local" (NO isolation — dev only) or "noop"
AE_SANDBOX_BACKEND=docker

# Model tier -> Fireworks model id (LiteLLM ids)
AE_MODEL_FRONTIER=fireworks_ai/accounts/fireworks/models/llama-v3p1-70b-instruct
AE_MODEL_LOCAL=fireworks_ai/accounts/fireworks/models/llama-v3p1-8b-instruct
