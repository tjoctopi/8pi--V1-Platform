# Copy to .env and fill in. Never commit .env.

# --- BYOM Model Gateway (Fireworks AI, open-source models via LiteLLM) ---
FIREWORKS_API_KEY=

# --- Engine config (all optional; sensible defaults in attack_engine.config) ---
# AE_ prefix maps to attack_engine.config.Settings fields.
AE_ENV=dev
AE_LOG_LEVEL=INFO
AE_LOG_JSON=false

# Audit log backend: "sqlite" (default) or "memory" or "postgres"
AE_AUDIT_BACKEND=sqlite
AE_AUDIT_SQLITE_PATH=./data/audit.db
# AE_AUDIT_POSTGRES_DSN=postgresql://user:pass@localhost:5432/attack_engine

# Results store backend — persists assets/findings/tool-runs/agent-runs so they
# survive an API restart/redeploy (the store rehydrates on engagement re-open).
# "memory" (code default, ephemeral) | "sqlite" (durable, pilot) | "postgres" (scale).
# A deployment SHOULD set this to sqlite (or postgres) — memory loses results on restart.
AE_STORE_BACKEND=sqlite
AE_STORE_SQLITE_PATH=./data/store.db
# AE_STORE_POSTGRES_DSN=postgresql://user:pass@localhost:5432/attack_engine

# Event bus backend: "memory" (default) or "redis"
AE_EVENTBUS_BACKEND=memory
# AE_EVENTBUS_REDIS_URL=redis://localhost:6379/0

# Knowledge graph backend: "networkx" (default, in-proc) or "neo4j"
AE_GRAPH_BACKEND=networkx
# AE_NEO4J_URL=bolt://localhost:7687
# AE_NEO4J_USER=neo4j
# AE_NEO4J_PASSWORD=
# AE_NEO4J_DATABASE=default

# Tool sandbox backend: "docker" (default) or "local" (NO isolation — dev only) or "noop"
AE_SANDBOX_BACKEND=docker

# Model tier -> Fireworks model id (LiteLLM ids)
AE_MODEL_FRONTIER=fireworks_ai/accounts/fireworks/models/llama-v3p1-70b-instruct
AE_MODEL_LOCAL=fireworks_ai/accounts/fireworks/models/llama-v3p1-8b-instruct

# --- Anthropic (frontier tier via BYOM gateway; optional) ---
ANTHROPIC_API_KEY=

# --- API shell (auth + web) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AE_API_JWT_SECRET=
AE_API_ADMIN_EMAIL=admin@8pi.local
AE_API_ADMIN_PASSWORD=
# CORS origins for the console (comma-separated), e.g. https://app.8pi.ai
AE_API_ORIGINS=

# --- Offensive tool sandbox ---
# Host Docker network the sandboxed tool containers join so they can reach the
# authorized targets. For the local range: attack-engine-range_range_net
AE_SANDBOX_NETWORK=

# --- HTTP port the frontend (nginx) listens on ---
HTTP_PORT=80
