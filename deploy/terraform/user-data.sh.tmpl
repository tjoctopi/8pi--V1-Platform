#!/bin/bash
# 8pi EC2 bootstrap (cloud-init user-data). Runs once as root on first boot.
# Installs Docker + docker compose, clones the repo, writes .env (engine AE_* vars),
# creates the tool sandbox network, pre-pulls tool images, brings the stack up, then
# optionally installs a Let's Encrypt cert via certbot + nginx on the host.

set -euo pipefail
exec > >(tee -a /var/log/8pi-bootstrap.log) 2>&1

echo "[8pi] bootstrap started at $(date -u)"

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y ca-certificates curl gnupg lsb-release ufw git jq

# ── Docker ──
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
  > /etc/apt/sources.list.d/docker.list
apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
usermod -aG docker ubuntu
systemctl enable --now docker

# ── App source ──
install -o ubuntu -g ubuntu -d /opt/8pi
cd /opt/8pi
sudo -u ubuntu git clone --branch "${branch}" "${repo_url}" src
cd src

# ── .env for the engine (attack_engine AE_* vars) ──
cat > /opt/8pi/src/.env <<EOF
AE_ENV=prod
AE_LOG_JSON=true
# auth / shell
AE_API_JWT_SECRET=${ae_api_jwt_secret}
AE_API_ADMIN_EMAIL=${ae_api_admin_email}
AE_API_ADMIN_PASSWORD=${ae_api_admin_password}
AE_API_ORIGINS=$([ -n "${domain}" ] && echo "https://${domain}" || echo "")
# BYOM model gateway
FIREWORKS_API_KEY=${fireworks_api_key}
ANTHROPIC_API_KEY=${anthropic_api_key}
AE_MODEL_MOCK=${ae_model_mock}
# offensive tool sandbox
AE_SANDBOX_BACKEND=docker
AE_SANDBOX_NETWORK=${ae_sandbox_network}
# governance state (in-proc defaults; set Postgres/Redis/Neo4j here for prod)
AE_AUDIT_BACKEND=sqlite
AE_EVENTBUS_BACKEND=memory
AE_GRAPH_BACKEND=networkx
# web
HTTP_PORT=80
REACT_APP_BACKEND_URL=
EOF
chmod 600 /opt/8pi/src/.env
chown ubuntu:ubuntu /opt/8pi/src/.env

# ── Offensive tool sandbox network + pre-pulled tool images ──
# Tool containers join this network to reach the authorized targets.
docker network create "${ae_sandbox_network}" 2>/dev/null || true
for img in instrumentisto/nmap:latest projectdiscovery/httpx:latest \
           projectdiscovery/nuclei:latest projectdiscovery/katana:latest secsi/ffuf:latest; do
  docker pull "$img" || echo "[8pi] warn: could not pre-pull $img (will pull on demand)"
done
# Seed nuclei templates into a named volume so scans never phone home on first run.
docker run --rm -v ae-nuclei-templates:/root/nuclei-templates \
  projectdiscovery/nuclei:latest -update-templates || echo "[8pi] warn: nuclei template seed failed"

# ── Build + bring the stack up (api = real engine, frontend = SPA) ──
cd /opt/8pi/src
sudo -u ubuntu docker compose --project-name 8pi build
sudo -u ubuntu docker compose --project-name 8pi up -d

# ── UFW firewall ──
ufw --force reset >/dev/null
ufw default deny incoming
ufw default allow outgoing
ufw allow 22/tcp
ufw allow 80/tcp
ufw allow 443/tcp
ufw --force enable

# ── Optional TLS via certbot when a domain is configured ──
if [ -n "${domain}" ] && [ -n "${tls_email}" ]; then
  echo "[8pi] provisioning Let's Encrypt cert for ${domain}"
  apt-get install -y certbot python3-certbot-nginx nginx
  # Stop the docker frontend so certbot standalone can bind 80.
  sudo -u ubuntu docker compose --project-name 8pi stop frontend
  certbot certonly --standalone --non-interactive --agree-tos \
    -m "${tls_email}" -d "${domain}" || echo "[8pi] certbot failed — continuing on plain HTTP"
  # Configure host nginx to terminate TLS and forward to the compose frontend on 8080.
  cat > /etc/nginx/sites-available/8pi <<NGX
server {
  listen 80;
  server_name ${domain};
  return 301 https://\$host\$request_uri;
}
server {
  listen 443 ssl http2;
  server_name ${domain};
  ssl_certificate     /etc/letsencrypt/live/${domain}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/${domain}/privkey.pem;

  client_max_body_size 20m;
  location / {
    proxy_pass         http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_set_header   Host              \$host;
    proxy_set_header   X-Real-IP         \$remote_addr;
    proxy_set_header   X-Forwarded-For   \$proxy_add_x_forwarded_for;
    proxy_set_header   X-Forwarded-Proto https;
    proxy_buffering    off;
    proxy_read_timeout 900s;
  }
}
NGX
  ln -sf /etc/nginx/sites-available/8pi /etc/nginx/sites-enabled/8pi
  rm -f /etc/nginx/sites-enabled/default
  # Restart the compose frontend on port 8080 instead of 80.
  sed -i 's/HTTP_PORT=80/HTTP_PORT=8080/' /opt/8pi/src/.env
  sudo -u ubuntu docker compose --project-name 8pi up -d
  systemctl reload nginx || systemctl restart nginx
fi

echo "[8pi] bootstrap complete at $(date -u)"
